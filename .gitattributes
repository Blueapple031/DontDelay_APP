# 모든 텍스트 파일은 LF로 통일 (팀 협업 줄바꿈 충돌 방지)
* text=auto eol=lf

# Dart/Flutter 파일
*.dart text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.xml text eol=lf

# 바이너리 파일 (변환 안 함)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
